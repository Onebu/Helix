# Helix Environment Variables
# Copy to .env and fill in your values: cp .env.example .env

# ──────────────────────────────────────────────────────────────
# Provider API Keys (at least one required)
# ──────────────────────────────────────────────────────────────

# OpenRouter — default provider for all roles
GENE_OPENROUTER_API_KEY=your-openrouter-api-key-here

# Alternative providers (only needed if you override the default)
# GENE_GEMINI_API_KEY=your-gemini-api-key-here
# GENE_OPENAI_API_KEY=your-openai-api-key-here

# ──────────────────────────────────────────────────────────────
# Database
# ──────────────────────────────────────────────────────────────

# SQLite (default, good for local dev)
# GENE_DATABASE_URL=sqlite+aiosqlite:///./helix.db

# PostgreSQL (for Docker: docker compose --profile postgres up)
# GENE_DATABASE_URL=postgresql+asyncpg://helix:helix_dev@postgres:5432/helix
# POSTGRES_PASSWORD=change-me-in-production

# ──────────────────────────────────────────────────────────────
# Model Configuration (optional — defaults shown)
# ──────────────────────────────────────────────────────────────

# GENE_META_MODEL=anthropic/claude-sonnet-4
# GENE_TARGET_MODEL=openai/gpt-4o-mini
# GENE_JUDGE_MODEL=anthropic/claude-sonnet-4
# GENE_META_PROVIDER=openrouter
# GENE_TARGET_PROVIDER=openrouter
# GENE_JUDGE_PROVIDER=openrouter

# ──────────────────────────────────────────────────────────────
# Server Configuration (optional)
# ──────────────────────────────────────────────────────────────

# CORS origins (comma-separated). Default: localhost dev ports
# CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Rate limiting (requests per minute, 0 = disabled)
# RATE_LIMIT_PER_MINUTE=120
# RATE_LIMIT_EVOLUTION=10

# ──────────────────────────────────────────────────────────────
# Authentication (optional — disabled by default)
# ──────────────────────────────────────────────────────────────
# Helix runs in single-user developer mode by default (no login required).
# Set HELIX_AUTH_DISABLED=false to enable multi-user mode with JWT auth.

# HELIX_AUTH_DISABLED=true
# HELIX_SECRET_KEY=generate-a-random-secret-here
# HELIX_JWT_EXPIRY_HOURS=24
